<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>

    <!-- NuGet Package Metadata -->
    <PackageId>WrapSplash</PackageId>
    <Version>1.0.0</Version>
    <Authors>Sandeep Vattapparambil</Authors>
    <Description>A simple .NET wrapper module for the Unsplash API. Port of the popular wrapsplash npm package.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/SandeepVattapparambil/wrapsplash</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Sandeepv68/wrapsplash.net.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>unsplash;api;images;photos;wrapper</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Http.Polly" Version="9.0.0" />
    <PackageReference Include="Polly" Version="8.5.2" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="WrapSplash.NET.Tests" />
  </ItemGroup>

</Project>
